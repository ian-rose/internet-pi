# {{ ansible_managed }}
---
# Use the same networks as internet-monitoring.
{# Make sure pihole and nginx-proxy are in the same network #}
networks:
{% if domain_enable %}
  front-tier:
    name: internet-monitoring-front-tier
    external: true
{% endif %}
  back-tier:
    name: internet-monitoring-back-tier
    external: true

# More info at https://github.com/pi-hole/docker-pi-hole/ and https://docs.pi-hole.net/
services:
  pihole:
    container_name: pihole
    image: pihole/pihole:latest
    restart: unless-stopped
    hostname: {{ subdomains['pihole'] }}
    ports:
      - "53:53/tcp"
      - "53:53/udp"
      - "67:67/udp"
{% if domain_enable %}
      - "38080:80/tcp"
      - "3443:443/tcp"
{% else %}
      - "80:80/tcp"
      - "443:443/tcp"
{% endif %}
    environment:
      TZ: '{{ pihole['timezone'] }}'
      FTLCONF_webserver_api_password: '{{ pihole['password'] }}'
      WEBPASSWORD: '{{ pihole['password'] }}'
      FTLCONF_dns_listeningMode: '{{ pihole['dns_listeningMode'] }}'
{% if domain_enable and domain and subdomains['pihole'] %}
      VIRTUAL_HOST: {{ subdomains['pihole'] }}.{{ domain }}
      VIRTUAL_PORT: 80
{% if ssl_enable %}
      LETSENCRYPT_HOST: {{ subdomains['pihole'] }}.{{ domain }}
{% endif %}
      PROXY_LOCATION: {{ subdomains['pihole'] }}
    networks:
      - front-tier
      - back-tier
{% endif %}
    dns:
      - 127.0.0.1
      - 8.8.8.8
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - './etc-pihole/:/etc/pihole/'
      - './etc-dnsmasq.d/:/etc/dnsmasq.d/'
    cap_add:
      - NET_ADMIN

  pihole-exporter:
    container_name: pihole-exporter
    image: ekofr/pihole-exporter:latest
    restart: unless-stopped
    hostname: 'pihole-exporter'
    ports:
      - "9617:9617"
    environment:
      PIHOLE_HOSTNAME: '{{ subdomains['pihole'] }}'
      PIHOLE_PASSWORD: '{{ pihole['password'] }}'
      INTERVAL: '30s'
      PORT: 9617
    networks:
      - back-tier
