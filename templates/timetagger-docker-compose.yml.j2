# {{ ansible_managed }}
---

# Use the same networks as internet-monitoring.
{# Make sure timetagger and nginx-proxy are in the same network #}
{% if domain.enable and domain.base and domain.subdomains.timetagger %}
networks:
  front-tier:
    name: internet-monitoring-front-tier
    external: true
{% endif %}

services:
  timetagger:
    container_name: timetagger
    image: ghcr.io/almarklein/timetagger
    restart: unless-stopped
    hostname: '{{ services.timetagger.hostname }}'
    ports:
      - "8080:8080"
    environment:
      TIMETAGGER_BIND: 0.0.0.0:8080
      TIMETAGGER_DATADIR: /root/_timetagger
      TIMETAGGER_LOG_LEVEL: info
      TIMETAGGER_CREDENTIALS: '{{ services.timetagger.user }}:{{ services.timetagger.password }}'
{% if domain.enable and domain.base and domain.subdomains.timetagger %}
      VIRTUAL_HOST: '{{ domain.subdomains.timetagger }}.{{ domain.base }}'
      VIRTUAL_PORT: 8080
{% if services.ssl.enable %}
      LETSENCRYPT_HOST: {{ domain.subdomains.timetagger }}.{{ domain.base }}
{% endif %}
{% endif %}
    volumes:
      - ./_timetagger:/root/_timetagger
{% if domain.enable and domain.base and domain.subdomains.timetagger %}
    networks:
      - front-tier
{% endif %}
